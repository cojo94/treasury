@namespace Treasury.Web.Components

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Recent Transactions</h5>
            <span class="text-muted small">Last 5 entries</span>
        </div>

        <div class="list-group list-group-flush">
            @foreach (TransactionItem transaction in TransactionItems)
            {
                <div class="list-group-item px-0 py-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">@transaction.Description</div>
                            <div class="text-muted small">
                                @transaction.Date.ToString("MMM d, yyyy") • @transaction.Category
                            </div>
                        </div>
                        <span class="fw-bold @(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                            @(transaction.Amount >= 0 ? "+" : "-")@FormatCurrency(Math.Abs(transaction.Amount))
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public required List<TransactionItem> TransactionItems { get; set; }

    private static string FormatCurrency(decimal amount)
    {
        return amount.ToString("C0");
    }
}