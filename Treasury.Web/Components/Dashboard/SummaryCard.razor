<div class="card shadow-sm border-0 h-100">
    <div class="card-body">
        <p class="text-muted mb-2">@Title</p>
        <h2 class="mb-0 @GetValueClass()">@Value</h2>
        @if (!string.IsNullOrWhiteSpace(Subtext))
        {
            <div class="text-muted small mt-2">@Subtext</div>
        }
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string Subtext { get; set; } = string.Empty;

    [Parameter]
    public decimal? NumericValue { get; set; }

    private string GetValueClass()
    {
        if (NumericValue.HasValue)
        {
            return NumericValue.Value > 0 ? "text-success" : NumericValue.Value < 0 ? "text-danger" : "";
        }
        return "";
    }
}