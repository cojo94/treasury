@page "/"
@using System.Globalization
@using Treasury.Web.Models

<PageTitle>Treasury Dashboard</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-1">Treasury Dashboard</h1>
            <p class="text-muted mb-0">A quick snapshot of your finances.</p>
        </div>
        <span class="badge bg-success-subtle text-success-emphasis">Mock data</span>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <SummaryCard Title="Current Balance" Value="@FormatCurrency(Dashboard.Balance)" Subtext="Updated Today" />
        </div>

        <div class="col-md-4">
            <SummaryCard Title="Monthly Income" Value="@FormatCurrency(Dashboard.MonthlyIncome)"
                         NumericValue="Dashboard.MonthlyIncome" />
        </div>

        <div class="col-md-4">
            <SummaryCard Title="Monthly Expenses" Value="@FormatCurrency(Dashboard.MonthlyExpenses)"
                         NumericValue="-Dashboard.MonthlyExpenses" />
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Recent Transactions</h5>
                        <span class="text-muted small">Last 5 entries</span>
                    </div>

                    <div class="list-group list-group-flush">
                        @foreach (var transaction in Dashboard.Transactions)
                        {
                            <div class="list-group-item px-0 py-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">@transaction.Description</div>
                                        <div class="text-muted small">@transaction.Date.ToString("MMM d, yyyy") •
                                            @transaction.Category</div>
                                        </div>
                                        <span class="fw-bold @(transaction.Amount >= 0 ? "text-success" : "text-danger")">
                                            @(transaction.Amount >= 0 ? "+" : "-")@FormatCurrency(Math.Abs(transaction.Amount))
                                        </span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <h5 class="mb-3">Savings Goal</h5>
                        <p class="text-muted mb-3">You are on track with your monthly savings target.</p>

                        <div class="progress" role="progressbar" aria-label="Savings progress" aria-valuemin="0"
                             aria-valuemax="100">
                            <div class="progress-bar bg-success"
                                 style="width: @(Dashboard.SavingsProgress.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%">
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-2 text-muted small">
                            <span>Progress</span>
                            <span>@Dashboard.SavingsProgress%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private HomeDashboardModel Dashboard { get; } = new()
    {
        Balance = 12540.75m,
        MonthlyIncome = 5200.00m,
        MonthlyExpenses = 2850.00m,
        SavingsProgress = 73.5m,
        Transactions =
        [
            new TransactionItem { Date = new DateTime(2026, 6, 28), Description = "Paycheck", Amount = 3200.00m, Category = "Income" },
            new TransactionItem { Date = new DateTime(2026, 6, 25), Description = "Groceries", Amount = -124.80m, Category = "Food" },
            new TransactionItem { Date = new DateTime(2026, 6, 22), Description = "Freelance Project", Amount = 850.00m, Category =
"Income" },
            new TransactionItem { Date = new DateTime(2026, 6, 20), Description = "Electric Bill", Amount = -92.40m, Category =
"Utilities" },
            new TransactionItem { Date = new DateTime(2026, 6, 18), Description = "Streaming Subscription", Amount = -15.99m,
Category = "Entertainment" }
        ]
    };

    private static string FormatCurrency(decimal amount)
        => amount.ToString("C0", CultureInfo.CurrentCulture);
}